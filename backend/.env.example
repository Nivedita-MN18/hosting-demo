# PostgreSQL connection string
DATABASE_URL=postgres://tracelite:tracelite@localhost:5432/tracelite

# Static API key — set this on the server, use the same value in middleware SDK
TRACELITE_API_KEY=dev-secret-key

# HTTP port for the API server
PORT=3001

# Set to "production" in prod so Express disables stack traces in errors
NODE_ENV=development
